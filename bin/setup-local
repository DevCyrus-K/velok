#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

cd "$ROOT_DIR"

"$ROOT_DIR/bin/bootstrap-local-php"

if [[ ! -f .env ]]; then
    cp .env.example .env
fi

mkdir -p database
touch database/database.sqlite

if ! rg -q '^APP_KEY=base64:' .env; then
    "$ROOT_DIR/bin/velok-php" artisan key:generate --ansi
fi

"$ROOT_DIR/bin/velok-php" artisan migrate --seed --force
npm install
npm run build
rm -f public/hot

printf '\nLocal setup complete.\n'
printf 'Serve built assets with: ./bin/serve-local\n'
printf 'Run live dev mode with: composer run local:dev\n'
